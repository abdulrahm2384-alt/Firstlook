# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# COCKROACH_DB_URL: Connection URL for CockroachDB Cluster (PostgreSQL compatible)
# Format e.g. postgresql://user:password@host:port/dbname?sslmode=verify-full
COCKROACH_DB_URL=

# JWT_SECRET: Secret key for signing session JWTs
JWT_SECRET=

# GOOGLE ADSENSE (OPTIONAL):
# Custom AdSense credentials. Configure to trigger real Google Display ad slots.
VITE_ADSENSE_CLIENT=ca-pub-XXXXXXXXXXXXXXXX
VITE_ADSENSE_SLOT=XXXXXXXXXX

# PAYSTACK CONFIGURATION (OPTIONAL):
# Use to activate live Paystack checkout processing. If blank, automatically simulates transactions.
PAYSTACK_SECRET_KEY=
VITE_PAYSTACK_PUBLIC_KEY=
# PAYSTACK_MERCHANT_CURRENCY: Set to primary currency (NGN, GHS, KES, ZAR) of your Paystack account if it does not support USD values.
PAYSTACK_MERCHANT_CURRENCY=NGN
# PAYSTACK_MODE: Explicitly set billing environment mode. Options: 'test' or 'live'. 
# If not specified, the system auto-detects based on your PAYSTACK_SECRET_KEY prefix (sk_test_ vs sk_live_).
PAYSTACK_MODE=test

# TRUSTPILOT CONFIGURATION (OPTIONAL):
# Use to invite users or send reviews directly to Trustpilot.
TRUSTPILOT_API_KEY=
TRUSTPILOT_BUSINESS_UNIT_ID=

# ZOHO MAIL SMTP CONFIGURATION (OPTIONAL):
# Used to enable email OTP and welcome messages at registration. If not provided, accounts are created instantly.
ZOHO_MAIL_USER=
ZOHO_MAIL_PASS=
ZOHO_MAIL_HOST=
ZOHO_MAIL_PORT=

# RESEND API CONFIGURATION (RECOMMENDED FALLBACK):
# Extremely helpful if cloud firewalls (like Render's Free tier) block standard outbound SMTP ports (25, 465, 587).
# If RESEND_API_KEY is configured, emails are dispatched securely via Resend's HTTPS REST API (Port 443).
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SUPPORT RECIPIENT EMAIL (OPTIONAL):
# The email address that will receive contact form submissions and user feedback ratings.
# If not specified, defaults to ZOHO_MAIL_USER (or support@firstlooklabs.xyz).
SUPPORT_RECIPIENT_EMAIL=support@firstlooklabs.xyz

# ADMIN ANALYTICS & SUPPORT API CONFIGURATION
FOREX_API_SECRET=your_admin_api_secret_key_here
FOREX_API_URL=https://datawarehouse-vi6d.onrender.com


